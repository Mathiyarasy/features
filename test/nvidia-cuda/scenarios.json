{
    "install_all_options": {
        "image": "debian",
        "features": {
            "nvidia-cuda": {
                "installCudnn": true,
                "installCudnnDev": true,
                "installNvtx": true,
                "installToolkit": true
            }
        }
    },
    "install_cudnn_nvxt_version": {
        "image": "debian",
        "features": {
            "nvidia-cuda": {
                "installCudnn": true,
                "installNvtx": true,
                "cudaVersion": "12.3",
                "cudnnVersion": "9.4.0.58"
            }
        }
    }
}